{
  "name": "@app-template/backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
    "start": "node dist/index.js",
    "lint:eslint": "eslint . --fix --cache",
    "lint:oxlint": "oxlint . --fix",
    "lint": "pnpm run lint:eslint && pnpm run lint:oxlint",
    "format": "prettier --write . --config ../shared/prettier.config.mjs --ignore-path ../shared/.prettierignore",
    "test": "vitest",
    "test:unit": "vitest test/unit",
    "test:integration": "vitest test/integration",
    "test:coverage": "vitest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@app-template/shared": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/vite-build": "^1.11.1",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.5",
    "postgres": "^3.4.9",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-oxlint": "~1.50.0",
    "oxlint": "~1.50.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}

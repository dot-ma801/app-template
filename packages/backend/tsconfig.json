{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/src/*"] 
    },
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": true
  },
  "exclude": ["node_modules", "test", "drizzle.config.ts", "vite.config.ts"],
  "ts-node": {
    "compilerOptions": {
      "module": "NodeNext"
    }
  }
}
